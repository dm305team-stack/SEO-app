# === Bright Data APIs ===
BRIGHTDATA_API_KEY=your-brightdata-api-key
BRIGHTDATA_BROWSER_WSS=wss://brd-customer-XXXXX-zone-seo_geo:PASSWORD@brd.superproxy.io:9222
BRIGHTDATA_SCRAPING_BROWSER_WSS=wss://brd-customer-XXXXX-zone-scraping_browse:PASSWORD@brd.superproxy.io:9222

# === Other APIs ===
SERPAPI_API_KEY=your-serpapi-key
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key

# ============================================
# GOOGLE APIs - OAuth 2.0 Credentials
# Used by: Business Profile, Search Console,
#          Analytics, Indexing API
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ============================================
# GOOGLE APIs - API Key
# Used by: PageSpeed, Custom Search,
#          Safe Browsing, Knowledge Graph,
#          YouTube, Maps/Places
# ============================================
GOOGLE_API_KEY=your_google_api_key_here

# === App Config ===
NEXT_PUBLIC_APP_URL=https://toolbox.growthmarketingstudios.com
PORT=3000
